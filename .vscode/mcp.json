{
	"servers": {
		"infraflowsculptor-mcp": {
			"type": "http",
			"url": "http://127.0.0.1:5258/mcp",
			"headers": {
				"Authorization": "Bearer ${input:ifs_pat}"
			}
		},
		"com.postman/postman-mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@postman/postman-mcp-server@2.8.4"
			],
			"env": {
				"POSTMAN_API_KEY": "${input:POSTMAN_API_KEY}"
			}
		},
		"aspire": {
			"type": "stdio",
			"command": "aspire",
			"args": [
				"agent",
				"mcp",
				"--non-interactive"
			]
		},
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-github@0.33.0"
			],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${input:token}"
			}
		},
		"gitnexus": {
			"type": "stdio",
			"command": "cmd",
			"args": [
				"/c",
				"gitnexus",
				"mcp"
			]
		},
		"microsoft/azure-devops-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@azure-devops/mcp@1.0.0",
				"${input:ado_org}",
				"-d",
				"${input:ado_domain}"
			]
		},
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp"
			]
		},
		"graphify": {
			"type": "stdio",
			"command": "python",
			"args": [
				"-m",
				"graphify.serve",
				"graphify-out/graph.json"
			]
		}
	},
	"inputs": [
		{
			"id": "ifs_pat",
			"type": "promptString",
			"description": "InfraFlowSculptor personal access token (generate from Settings > Personal Access Tokens).",
			"password": true
		},
		{
			"id": "POSTMAN_API_KEY",
			"type": "promptString",
			"description": "A valid Postman API key.",
			"password": true
		},
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		},
		{
			"id": "ado_org",
			"type": "promptString",
			"description": "Azure DevOps organization name (e.g., contoso).",
			"password": false
		},
		{
			"id": "ado_domain",
			"type": "promptString",
			"description": "Repeat to enable specific domains: core, work, work-items, search, test-plans, repositories, wiki, pipelines, advanced-security.",
			"password": false
		}
	]
}